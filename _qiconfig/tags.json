{
  "schema_version": "2.0",
  "name": "QiLabs Global Tag Registry",
  "description": "Lean global tag vocabulary for QiLabs Markdown, vault, repo, docs, records, configs, and operational notes. Project-specific tags belong in folder-level overlay tags.json files.",
  "scope": "global",
  "registry_type": "base",
  "updated_at": "2026-07-01",
  "tag_policy": {
    "allow_new_tags": false,
    "minimum_tags_per_note": 3,
    "maximum_tags_per_note": 8,
    "absolute_maximum_tags_per_note": 12,
    "always_include": [],
    "style": {
      "case": "lowercase",
      "separator": "hyphen",
      "namespace_separator": "/",
      "prefix_required": "#"
    },
    "instructions": [
      "Use global tags for broad classification only.",
      "Use folder-level overlay tags.json files for case, client, project, people, exhibit, and domain-specific tags.",
      "Prefer one type tag, one status tag, and one sensitivity or visibility tag when possible.",
      "Do not add tags merely because a word appears in the note; tag the note's purpose and handling needs.",
      "Do not auto-apply folder overlay defaults outside the folder where the overlay was found.",
      "Flag unknown tags for review instead of deleting them automatically."
    ]
  },
  "overlay_policy": {
    "enabled": true,
    "inherit_global": true,
    "overlay_file_names": [
      "tags.json",
      "_qiconfig/tags.json",
      ".qilabs/tags.json"
    ],
    "resolution": "For each Markdown file, load the global registry first, then merge overlay registries found from the vault/repo root down to the file's folder.",
    "merge_rules": {
      "allowed_tags": "union by category; overlay tags are valid only for files under the overlay folder",
      "folder_defaults": "deep merge; nearest overlay wins on same folder key",
      "keyword_suggestions": "deep merge; nearest overlay wins on same keyword",
      "minimum_tags_per_note": "max(global minimum, overlay minimum if provided)",
      "maximum_tags_per_note": "min(global absolute maximum, global maximum + overlay max_bonus if provided)",
      "always_include": "overlay-only; never applied globally unless declared in global registry"
    },
    "default_overlay_max_bonus": 2,
    "require_overlay_scope": true
  },
  "allowed_tags": {
    "system": [
      "#qilabs",
      "#system/qilabs",
      "#system/qiserver",
      "#system/qivault",
      "#system/qiapps",
      "#system/qicode",
      "#system/qimemo",
      "#system/qifinance",
      "#system/qiconfig"
    ],
