{
  "schema_version": "2.0",
  "name": "Lisa Care Record 2026 Tag Overlay",
  "description": "Folder-level overlay for Lisa Care Record notes, evidence, timeline, exhibits, medical context, communications, and related caregiver record materials.",
  "scope": "folder",
  "registry_type": "overlay",
  "applies_to": "./",
  "inherits": "global",
  "tag_policy": {
    "allow_new_tags_within_overlay": false,
    "minimum_tags_per_note": 3,
    "max_bonus": 4,
    "always_include": [
      "#project/lisa-care-record"
    ],
    "instructions": [
      "Use this overlay only inside the Lisa Care Record folder tree.",
      "Use allegation tags only when the note discusses an accusation or claim.",
      "Use fact tags when the note supports or rebuts an allegation.",
      "Use exhibit tags based on the folder or evidence category.",
      "Use sensitivity and visibility tags based on disclosure risk."
    ]
  },
